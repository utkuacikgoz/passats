ANTHROPIC_API_KEY=sk-ant-...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
JWT_SECRET=generate-a-random-64-char-hex-string
# Optional — previous JWT secret for graceful key rotation (set during rollover)
# JWT_SECRET_PREV=old-secret-here
PORT=3000
BASE_URL=http://localhost:3000

# Required — atomic token single-use (replay protection)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# Optional — gates /api/health endpoint
HEALTH_SECRET=any-random-string

# Set to 'true' for local development (mocks payments + analysis)
# DEV_MODE=true
